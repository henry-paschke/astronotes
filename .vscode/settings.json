{
  "appService.zipIgnorePattern": [
    "**/node_modules{,/**}",
    "**/.vscode{,/**}",
    "**/.venv{,/**}",
    "**/venv{,/**}",
    "**/__pycache__{,/**}",
    "**/.env{,/**}",
    "**/.git{,/**}",
    "**/dist{,/**}",
    "**/build{,/**}",
    "**/.next{,/**}",
    "**/*.log",
    "**/*.md"
  ],
  "appService.defaultWebAppToDeploy": "None",
  "appService.showBuildDuringDeployPrompt": false
}
